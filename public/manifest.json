{
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "128": "icons/logo_128.png",
      "16": "icons/logo_16.png",
      "48": "icons/logo_48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "css": ["css/content.css"],
      "js": ["content-script.js"],
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "commands": {
    "_execute_action": {
      "description": "Open SaySo Snip",
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  },
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "host_permissions": [
    "*://*/*",
    "wss://openspeech.bytedance.com/*",
    "http://127.0.0.1:1995/*",
    "http://127.0.0.1:1996/*",
    "https://api.exa.ai/*"
  ],
  "icons": {
    "128": "icons/logo_128.png",
    "16": "icons/logo_16.png",
    "48": "icons/logo_48.png"
  },
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "options_ui": {
    "open_in_tab": true,
    "page": "html/options.html"
  },
  "permissions": ["storage", "tabs", "activeTab", "downloads", "contextMenus", "scripting", "alarms", "history", "notifications", "cookies", "identity", "webNavigation", "offscreen", "sidePanel", "tabCapture", "declarativeNetRequestWithHostAccess"],
  "version": "1.5.0",
  "web_accessible_resources": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "http://127.0.0.1:1995/*"
      ],
      "resources": [
        "*.js",
        "lib/*",
        "lib/fontawesome/*",
        "lib/fontawesome/webfonts/*",
        "icons/*",
        "html/popup.html",
        "css/*"
      ]
    }
  ]
}
